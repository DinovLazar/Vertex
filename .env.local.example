# Claude API (required for chat widget)
ANTHROPIC_API_KEY=sk-ant-...

# AI provider selection — "claude" (default) or "ollama" (future migration)
AI_PROVIDER=claude

# Ollama config (only used when AI_PROVIDER=ollama; safe to leave blank now)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Widget kill switch — set to "false" to hide the widget sitewide
NEXT_PUBLIC_CHAT_ENABLED=true
